#!/bin/bash
#SBATCH --partition=defq
#SBATCH --job-name=VCF
#SBATCH --nodes=1
#SBATCH --cpus-per-task=20
#SBATCH --ntasks-per-node=1
#SBATCH --mem=8g
#SBATCH --time=02:00:00
#SBATCH --mail-user=XXX@nottingham.ac.uk
#SBATCH --mail-type=begin
#SBATCH --mail-type=fail
#SBATCH --mail-type=end
#SBATCH --output=XXX/slurm-%x-%j.out
#SBATCH --error=XXX/slurm-%x-%j.err

# load conda environment
source $HOME/.bash_profile
conda activate Rotation3

# Define files pathway
INPUT:XXX/vcf
OUTDIR:XXX/GWAS

# Create a new output directory
mkdir -p "$OUTDIR"

# Using bcftools to retain biallelic SNPs for this analysis. 
# Only keeps SNPs variant
bcftools view -m2 -M2 -v snps "$INPUT"/doggies_snps_imputed.vcf.gz -Oz -o "$OUTDIR"/doggies_snps.vcf.gz

# Index the vcf to directly jump to a genomic positions.
bcftools index "$OUTDIR"/doggies_snps.vcf.gz

# Convert VCF files into a binary format - allows plink to work.
# plink stores data in 3 coordinated files, a .bed, .bim, and .fam
plink --vcf "$OUTDIR"/doggies_snps.vcf.gz --double-id --allow-extra-chr --make-bed --out doggies_raw

conda deactivate
