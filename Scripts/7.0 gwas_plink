#!/bin/bash
#SBATCH --partition=defq
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --mem=50g
#SBATCH --time=1:00:00
#SBATCH --job-name=plink_gwas
#SBATCH --output=XXX/slurm-%x-%j.out
#SBATCH --error=XXX/slurm-%x-%j.err
#SBATCH --mail-type=ALL
#SBATCH --mail-user=XXX@nottingham.ac.uk

# load conda environment
source $HOME/.bash_profile
conda activate rotation3

#loading the plink module
module load plink-uoneasy/2.00a3.7-foss-2023a

INPUT=XXX/plink_data
OUTDIR=XXX/plink_data/gwas_plink

# create a new output directory
mkdir -p "$OUTDIR" 

# run GWAS using plink
# linear regression - quantitative trait
# output .assoc.linear table
plink --bfile "$INPUT"/doggies_raw \
 --allow-extra-chr --allow-no-sex --pheno "$OUTPUT"/pheno_doggies_height.txt \
 --linear --out "$OUTPUT"/gwas_height_doggies

# Deactivate conda environment
conda deactivate

