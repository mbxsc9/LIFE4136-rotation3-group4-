#!/bin/bash
#SBATCH --partition=defq
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --mem=50g
#SBATCH --time=1:00:00
#SBATCH --job-name=plink
#SBATCH --output=/gpfs01/share/BioinfMSc/life4136_2526/rotation3/group4/Scripts/Logs/slurm-%x-%j.out
#SBATCH --error=/gpfs01/share/BioinfMSc/life4136_2526/rotation3/group4/Scripts/Logs/slurm-%x-%j.err
#SBATCH --mail-type=ALL
#SBATCH --mail-user=mbxsc9@nottingham.ac.uk

# load Conda Environment
source $HOME/.bash_profile
conda activate rotation3 

# Define input file
INPUT=XXX/doggies_snps_imputed.vcf.gz
OUTDIR=XXX/plink_data

# creating a new output directory 
mkdir -p "$OUTDIR"

# Run Plink
# Convert VCF files into a binary format - allows plink to work.
# plink stores data in 3 coordinated files, a .bed, .bim, and .fam 
plink --vcf "$INPUT" --double-id --allow-extra-chr --make-bed --out "$OUTDIR"/doggies_raw

# QC filter to remove low quality SNPs and individuals before analysis.
plink --bfile "$OUTDIR"/doggies_raw --missing --allow-extra-chr --out "$OUTDIR"/doggies_missing

conda deactivate
