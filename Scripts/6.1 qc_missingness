#!/bin/bash
#SBATCH --partition=defq
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --mem=5g
#SBATCH --time=01:00:00
#SBATCH --job-name=plink_qc
#SBATCH --output=XXX/slurm-%x-%j.out
#SBATCH --error=XXX/slurm-%x-%j.err
#SBATCH --mail-type=ALL
#SBATCH --mail-user=XXX@nottingham.ac.uk

# load the conda environment
source $HOME/.bash_profile
conda activate rotation3

# Define input files
INPUT=XXX/plink_data
OUTDIR=XXX/plink_data/plink_QC_Genotype

# QC filter to remove low quality SNPs and indiviuals before analysis.
plink --bfile "$INPUT"/doggies_raw --allow-extra-chr --geno 0.3 --mind 0.6 --maf 0.05 --make-bed --out "$OUTDIR"/doggies_qc

conda deactivate
